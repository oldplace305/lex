# Discord Bot Token（Discord Developer Portalで取得）
DISCORD_TOKEN=your-token-here

# あなたのDiscord User ID（開発者モードでコピー）
OWNER_ID=your-discord-user-id-here

# Bot設定（変更不要）
BOT_PREFIX=!
CLAUDE_TIMEOUT=120
LOG_LEVEL=INFO

# 定期報告送信先チャンネルID（0=DMにフォールバック）
REPORT_CHANNEL_ID=0

# Claude Code CLI認証トークン（launchd環境で必要）
CLAUDE_OAUTH_TOKEN=
